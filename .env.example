# ──────────────────────────────────────────────
# Google Custom Search  (per Reddit + Upwork)
# 1. Vai su https://console.cloud.google.com
# 2. Crea un progetto (o usa uno esistente)
# 3. Abilita "Custom Search API" nella Libreria
# 4. Crea una API key in "Credenziali"
# 5. Vai su https://programmablesearchengine.google.com
# 6. Crea un motore di ricerca per: reddit.com, upwork.com
# 7. Copia il Search Engine ID
# ──────────────────────────────────────────────
GOOGLE_CSE_API_KEY=your_google_cse_api_key
GOOGLE_CSE_ID=your_custom_search_engine_id

# ──────────────────────────────────────────────
# Google Gemini  (https://aistudio.google.com/apikey)
# Gratuito — nessuna carta di credito richiesta
# ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ──────────────────────────────────────────────
# Telegram Bot  (parla con @BotFather su Telegram)
# Per ottenere CHAT_ID: invia un messaggio al bot,
# poi apri https://api.telegram.org/bot<TOKEN>/getUpdates
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
