# ──────────────────────────────────────────────
# Reddit API  (https://www.reddit.com/prefs/apps)
# Tipo app: "script"
# ──────────────────────────────────────────────
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# ──────────────────────────────────────────────
# Upwork API  (https://www.upwork.com/developer/keys/apply)
# OAuth2 — richiede registrazione app (opzionale)
# ──────────────────────────────────────────────
UPWORK_CLIENT_ID=your_upwork_client_id
UPWORK_CLIENT_SECRET=your_upwork_client_secret
UPWORK_ACCESS_TOKEN=your_upwork_access_token

# ──────────────────────────────────────────────
# Google Gemini  (https://aistudio.google.com/apikey)
# Gratuito — nessuna carta di credito richiesta
# ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ──────────────────────────────────────────────
# Telegram Bot  (parla con @BotFather su Telegram)
# Per ottenere CHAT_ID: invia un messaggio al bot,
# poi apri https://api.telegram.org/bot<TOKEN>/getUpdates
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
